<?xml version="1.0"?>
<typesystem package="PySide6Qlementine">

    <load-typesystem name="typesystem_core.xml" generate="no"/>
    <load-typesystem name="typesystem_gui.xml" generate="no"/>
    <load-typesystem name="typesystem_widgets.xml" generate="no"/>

    <!-- ====== REJECTED FREE FUNCTIONS ======
         These are internal C++ utilities that either generate broken shiboken
         overload code or operate on types not exposed in our bindings. -->
    <rejection class="oclero::qlementine" function-name="appStyle"/>
    <rejection class="" function-name="colorizeImage"/>
    <rejection class="" function-name="getColorizedPixmapKey"/>
    <rejection class="" function-name="getTintedPixmapKey"/>
    <rejection class="" function-name="makeRoundedPixmap"/>
    <rejection class="" function-name="makeFitPixmap"/>
    <rejection class="" function-name="getImageAspectRatio"/>
    <rejection class="" function-name="getExtendedImage"/>
    <rejection class="" function-name="getBlurredPixmap"/>
    <rejection class="" function-name="getDropShadowPixmap"/>
    <rejection class="" function-name="blurRadiusNecessarySpace"/>
    <rejection class="" function-name="getContrastRatio"/>
    <rejection class="" function-name="colorWithAlphaF"/>
    <rejection class="" function-name="colorWithAlpha"/>
    <rejection class="" function-name="getColorSourceOver"/>
    <rejection class="" function-name="tryGetColorFromVariantList"/>
    <rejection class="" function-name="tryGetColorFromRGBAString"/>
    <rejection class="" function-name="tryGetColorFromHexaString"/>
    <rejection class="" function-name="tryGetColorFromVariant"/>
    <rejection class="" function-name="toHexRGB"/>
    <rejection class="" function-name="toHexRGBA"/>
    <rejection class="" function-name="getStatusBadgeSizes"/>
    <rejection class="" function-name="drawStatusBadge"/>

    <!-- ====== REJECTED METHODS: std::function parameters ======
         Shiboken cannot marshal std::function<> types. -->
    <rejection class="oclero::qlementine::QlementineStyle" function-name="setIconPathGetter"/>
    <rejection class="oclero::qlementine::Menu" function-name="setEnabledPredicate"/>
    <rejection class="oclero::qlementine::Menu" function-name="setVisiblePredicate"/>
    <rejection class="oclero::qlementine::Popover" function-name="setManualPositioningCallback"/>

    <!-- ====== REJECTED METHODS: internal ====== -->
    <rejection class="oclero::qlementine::AbstractItemListWidget" function-name="initStyleOptionFocus"/>
    <rejection class="oclero::qlementine::CommandLinkButton" function-name="initStyleOption"/>

    <!-- ====== REJECTED CLASSES ======
         Internal implementation details, custom QStyleOption subclasses used
         only inside QlementineStyle's C++ drawing code (never passed across
         the Python boundary in QStyle virtual signatures), and classes not
         part of our public API. -->
    <rejection class="oclero::qlementine::WidgetAnimationManager"/>
    <rejection class="oclero::qlementine::WidgetAnimator"/>
    <rejection class="oclero::qlementine::ThemeEditor"/>
    <rejection class="oclero::qlementine::QStyleOptionFocusRoundedRect"/>
    <rejection class="oclero::qlementine::QStyleOptionRoundedButton"/>
    <rejection class="oclero::qlementine::QStyleOptionSliderF"/>
    <rejection class="oclero::qlementine::QStyleOptionCommandLinkButton"/>
    <rejection class="oclero::qlementine::ComboBoxDelegate"/>
    <rejection class="oclero::qlementine::Action"/>
    <rejection class="oclero::qlementine::FramelessWindow"/>

    <namespace-type name="oclero" visible="false">
        <namespace-type name="qlementine" visible="false">

            <!-- ====== ENUMS ====== -->
            <enum-type name="ColorRole"/>
            <enum-type name="MouseState"/>
            <enum-type name="CheckState"/>
            <enum-type name="FocusState"/>
            <enum-type name="ActiveState"/>
            <enum-type name="SelectionState"/>
            <enum-type name="AlternateState"/>
            <enum-type name="DefaultState"/>
            <enum-type name="Status"/>
            <enum-type name="TextRole"/>
            <enum-type name="ColorMode"/>
            <enum-type name="AutoIconColor"/>
            <enum-type name="StatusBadge"/>
            <enum-type name="StatusBadgeSize"/>
            <enum-type name="ColorizeMode"/>

            <!-- ====== VALUE TYPES ====== -->

            <value-type name="IconTheme"/>
            <value-type name="RadiusesF"/>
            <value-type name="ThemeMeta"/>
            <value-type name="Theme">
                <!-- std::optional<Theme> returns are dropped by shiboken; re-add via add-function -->
                <add-function signature="fromJsonPath(const QString&amp; @jsonPath@)" return-type="oclero::qlementine::Theme" static="yes">
                    <inject-code class="target" position="beginning">
                        auto result = oclero::qlementine::Theme::fromJsonPath(%1);
                        if (result.has_value()) {
                            oclero::qlementine::Theme cppResult = result.value();
                            %PYARG_0 = %CONVERTTOPYTHON[oclero::qlementine::Theme](cppResult);
                        } else {
                            PyErr_SetString(PyExc_ValueError, "Failed to load theme from JSON path");
                            return {};
                        }
                    </inject-code>
                </add-function>

                <add-function signature="fromJsonDoc(const QJsonDocument&amp; @jsonDoc@)" return-type="oclero::qlementine::Theme" static="yes">
                    <inject-code class="target" position="beginning">
                        auto result = oclero::qlementine::Theme::fromJsonDoc(%1);
                        if (result.has_value()) {
                            oclero::qlementine::Theme cppResult = result.value();
                            %PYARG_0 = %CONVERTTOPYTHON[oclero::qlementine::Theme](cppResult);
                        } else {
                            PyErr_SetString(PyExc_ValueError, "Failed to load theme from JSON document");
                            return {};
                        }
                    </inject-code>
                </add-function>
            </value-type>

            <!-- ====== OBJECT TYPES ====== -->

            <object-type name="QlementineStyle">
                <enum-type name="StandardPixmapExt"/>
                <enum-type name="ControlElementExt"/>
                <enum-type name="ContentsTypeExt"/>
                <enum-type name="PixelMetricExt"/>
                <enum-type name="PrimitiveElementExt"/>

                <!-- ====== QStyle/QProxyStyle virtual overrides ======
                     These MUST be declared so Shiboken generates the virtual
                     dispatch shim in QlementineStyleWrapper.  Without them,
                     the C++ vtable entry for QlementineStyle's override is
                     bypassed and Qt falls back to QCommonStyle.

                     Full exposure: callable from Python AND overridable by
                     Python subclasses.  allow-thread="yes" on painting methods
                     releases the GIL during the C++ call. -->

                <!-- Drawing -->
                <modify-function signature="drawPrimitive(QStyle::PrimitiveElement,const QStyleOption*,QPainter*,const QWidget*)const"
                                 allow-thread="yes"/>
                <modify-function signature="drawControl(QStyle::ControlElement,const QStyleOption*,QPainter*,const QWidget*)const"
                                 allow-thread="yes"/>
                <modify-function signature="drawComplexControl(QStyle::ComplexControl,const QStyleOptionComplex*,QPainter*,const QWidget*)const"
                                 allow-thread="yes"/>

                <!-- Metrics & layout -->
                <modify-function signature="pixelMetric(QStyle::PixelMetric,const QStyleOption*,const QWidget*)const"/>
                <modify-function signature="sizeFromContents(QStyle::ContentsType,const QStyleOption*,const QSize&amp;,const QWidget*)const"/>
                <modify-function signature="subElementRect(QStyle::SubElement,const QStyleOption*,const QWidget*)const"/>
                <modify-function signature="subControlRect(QStyle::ComplexControl,const QStyleOptionComplex*,QStyle::SubControl,const QWidget*)const"/>
                <modify-function signature="hitTestComplexControl(QStyle::ComplexControl,const QStyleOptionComplex*,const QPoint&amp;,const QWidget*)const"/>
                <modify-function signature="layoutSpacing(QSizePolicy::ControlType,QSizePolicy::ControlType,Qt::Orientation,const QStyleOption*,const QWidget*)const"/>

                <!-- Hints & icons -->
                <modify-function signature="styleHint(QStyle::StyleHint,const QStyleOption*,const QWidget*,QStyleHintReturn*)const"/>
                <modify-function signature="standardIcon(QStyle::StandardPixmap,const QStyleOption*,const QWidget*)const"/>
                <modify-function signature="standardPixmap(QStyle::StandardPixmap,const QStyleOption*,const QWidget*)const"/>
                <modify-function signature="generatedIconPixmap(QIcon::Mode,const QPixmap&amp;,const QStyleOption*)const"/>
                <modify-function signature="standardPalette()const"/>
                <!-- Polish / unpolish -->
                <modify-function signature="polish(QWidget*)"/>
                <modify-function signature="polish(QPalette&amp;)"/>
                <modify-function signature="polish(QApplication*)" remove="all"/>
                <modify-function signature="unpolish(QWidget*)"/>
                <modify-function signature="unpolish(QApplication*)" remove="all"/>

                <!-- Extended QStyle virtual methods -->
                <modify-function signature="drawPrimitiveExt(oclero::qlementine::QlementineStyle::PrimitiveElementExt,const QStyleOption*,QPainter*,const QWidget*)const"
                                 allow-thread="yes"/>
                <modify-function signature="drawControlExt(oclero::qlementine::QlementineStyle::ControlElementExt,const QStyleOption*,QPainter*,const QWidget*)const"
                                 allow-thread="yes"/>
                <modify-function signature="standardIconExt(oclero::qlementine::QlementineStyle::StandardPixmapExt,const QStyleOption*,const QWidget*)const"/>
                <modify-function signature="sizeFromContentsExt(oclero::qlementine::QlementineStyle::ContentsTypeExt,const QStyleOption*,const QSize&amp;,const QWidget*)const"/>
                <modify-function signature="pixelMetricExt(oclero::qlementine::QlementineStyle::PixelMetricExt,const QStyleOption*,const QWidget*)const"/>

                <!-- Qlementine-specific public method -->
                <modify-function signature="widgetStatus(const QWidget*)const"/>
            </object-type>

            <object-type name="ThemeManager"/>

            <object-type name="AbstractItemListWidget" force-abstract="yes"/>

            <object-type name="NavigationBar"/>
            <object-type name="SegmentedControl"/>
            <object-type name="Switch"/>
            <object-type name="Label"/>
            <object-type name="LineEdit"/>
            <object-type name="PlainTextEdit"/>
            <object-type name="LoadingSpinner"/>
            <object-type name="IconWidget"/>
            <object-type name="StatusBadgeWidget"/>
            <object-type name="ActionButton"/>
            <object-type name="AboutDialog"/>
            <object-type name="NotificationBadge"/>
            <object-type name="ColorButton"/>
            <object-type name="ColorEditor"/>
            <object-type name="RoundedFocusFrame"/>

            <object-type name="Expander">
                <modify-function signature="setContent(QWidget*)">
                    <modify-argument index="1">
                        <define-ownership class="target" owner="c++"/>
                    </modify-argument>
                </modify-function>
            </object-type>

            <object-type name="CommandLinkButton"/>

            <object-type name="Popover">
                <enum-type name="Position"/>
                <enum-type name="Alignment"/>
                <modify-function signature="setContentWidget(QWidget*)">
                    <modify-argument index="1">
                        <define-ownership class="target" owner="c++"/>
                    </modify-argument>
                </modify-function>
            </object-type>

            <object-type name="PopoverButton">
                <modify-function signature="setPopoverContentWidget(QWidget*)">
                    <modify-argument index="1">
                        <define-ownership class="target" owner="c++"/>
                    </modify-argument>
                </modify-function>
            </object-type>

            <object-type name="Menu"/>

        </namespace-type>
    </namespace-type>

</typesystem>